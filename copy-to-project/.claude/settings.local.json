{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "plansDirectory": "./docs/plans",
  "permissions": {
    "allow": [
      "Bash(ruff*)",
      "Bash(pytest*)",
      "Bash(python -m pytest*)",
      "Bash(mypy*)",
      "Bash(make check*)",
      "Bash(make test*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/web-fetch-markdown.ps1",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File .claude/hooks/validate-files.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
